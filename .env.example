# =====================================================
# CampusON 환경 변수 템플릿
# 사용법: cp .env.example .env 후 값을 채워주세요
# =====================================================

# --- 환경 ---
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# --- PostgreSQL ---
POSTGRES_USER=campuson
POSTGRES_PASSWORD=campuson_dev_pw
POSTGRES_DB=campuson
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy 비동기 드라이버 (asyncpg)
DATABASE_URL=postgresql+asyncpg://campuson:campuson_dev_pw@localhost:5432/campuson
# Alembic 동기 드라이버 (psycopg2)
DATABASE_URL_SYNC=postgresql+psycopg2://campuson:campuson_dev_pw@localhost:5432/campuson

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=campuson_dev_pw
REDIS_URL=redis://:campuson_dev_pw@localhost:6379/0

# --- JWT ---
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=CampusON

# --- SMTP Email ---
# Gmail: smtp.gmail.com / 587 / 앱 비밀번호
# Naver: smtp.naver.com / 587
# SMTP_ENABLED=false 이면 MOCK (로그만, 실제 발송 안 함)
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=CampusON
SMTP_USE_TLS=true
EMAIL_VERIFICATION_CODE_EXPIRE_MINUTES=10

# --- LLM (Day 6) ---
# 키가 없거나 LLM_PROVIDER=mock이면 mock provider로 자동 fallback됩니다.
LLM_PROVIDER=mock
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.3
LLM_TIMEOUT_SEC=60.0
LLM_MAX_RETRIES=3
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Embeddings (Day 8) ---
# 키가 없으면 mock provider로 자동 fallback.
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_BATCH_SIZE=96

# --- Chunking (Day 8) ---
CHUNK_TARGET_TOKENS=800
CHUNK_OVERLAP_TOKENS=150
CHUNK_MIN_TOKENS=200
CHUNK_MAX_TOKENS=1200

# --- 보안 ---
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# --- 감사 로그 ---
AUDIT_LOG_ENABLED=true
AUDIT_LOG_SKIP_PATHS=/,/docs,/redoc,/api/v1/openapi.json,/api/v1/health

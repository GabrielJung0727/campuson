# =====================================================
# CampusON 환경 변수 템플릿
# 사용법: cp .env.example .env 후 값을 채워주세요
# =====================================================

# --- 환경 ---
ENV=development
DEBUG=true
LOG_LEVEL=INFO

# --- PostgreSQL ---
POSTGRES_USER=campuson
POSTGRES_PASSWORD=campuson_dev_pw
POSTGRES_DB=campuson
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# SQLAlchemy 비동기 드라이버 (asyncpg)
DATABASE_URL=postgresql+asyncpg://campuson:campuson_dev_pw@localhost:5432/campuson
# Alembic 동기 드라이버 (psycopg2)
DATABASE_URL_SYNC=postgresql+psycopg2://campuson:campuson_dev_pw@localhost:5432/campuson

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=campuson_dev_pw
REDIS_URL=redis://:campuson_dev_pw@localhost:6379/0

# --- JWT ---
JWT_SECRET_KEY=change-me-in-production-please-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14

# --- API ---
API_HOST=0.0.0.0
API_PORT=8000
API_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Web (Next.js) ---
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
NEXT_PUBLIC_APP_NAME=CampusON

# --- AI (Day 6에서 사용) ---
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-large
# LLM_MODEL=claude-sonnet-4-6

# --- 보안 ---
BCRYPT_ROUNDS=12
PASSWORD_MIN_LENGTH=8

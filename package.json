{
  "name": "campuson",
  "version": "0.1.0",
  "private": true,
  "description": "CampusON · 경복대학교 보건계열 AI 학습튜터링 플랫폼 (모노레포 루트)",
  "workspaces": [
    "apps/web",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace apps/web",
    "build:web": "npm run build --workspace apps/web",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx --max-warnings 0",
    "lint:fix": "eslint . --ext .js,.jsx,.ts,.tsx --fix",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,md,yml,yaml}\"",
    "prepare": "node scripts/install-husky.mjs",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "api:dev": "cd apps/api && uvicorn app.main:app --reload --host 0.0.0.0 --port 8000",
    "api:migrate": "cd apps/api && alembic upgrade head",
    "api:makemigration": "cd apps/api && alembic revision --autogenerate -m",
    "generate:types": "cd apps/api && python ../../scripts/generate_api_types.py",
    "api:test": "cd apps/api && python -m pytest tests/ -v",
    "api:test:cov": "cd apps/api && python -m pytest tests/ -v --cov=app --cov-report=term-missing",
    "check:contracts": "cd apps/api && python ../../scripts/check_api_contracts.py"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.6",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "typescript": "^5.5.4"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ],
    "apps/api/**/*.py": [
      "bash -c 'cd apps/api && ruff check --fix'",
      "bash -c 'cd apps/api && black'"
    ]
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
